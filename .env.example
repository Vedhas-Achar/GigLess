# Shared environment file for the entire project (backend + frontend)

# Django
SECRET_KEY=change-this-secret
DEBUG=True

# Frontend (Vite)
VITE_API_BASE_URL=http://localhost:8000/api

# PostgreSQL (optional). If POSTGRES_DB is empty, SQLite is used.
POSTGRES_DB=
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres
POSTGRES_HOST=localhost
POSTGRES_PORT=5432
